# Streamlit Cloud 시크릿 템플릿
# 배포 시 앱 설정 > Secrets 에 아래 내용을 붙여넣으세요. (이 예시 파일만 커밋, 실제 secrets 는 커밋 금지)

OPENAI_API_KEY = "sk-여기에-본인-키"
OPENAI_MODEL = "gpt-5.4-nano"
OPENAI_EMBED_MODEL = "text-embedding-3-large"

# 리랭킹 (openai 권장; off 도 가능)
RERANK_BACKEND = "openai"

# (권장) 공개 배포 시 접속 비밀번호 — 설정하면 입력해야 사용 가능(비용 남용 방지).
# 비워두거나 생략하면 게이트 없음.
APP_PASSWORD = "원하는-비밀번호"

# 벡터 저장소
#   memory : 리포지토리에 포함한 storage/reports_openai.npz + chunks.jsonl 사용 (A안, 권장)
#   remote : 로컬에서 띄운 Chroma 서버에 터널로 접속 (C안)
VECTOR_BACKEND = "memory"

# --- VECTOR_BACKEND=remote(C안) 일 때만 ---
# CHROMA_HTTP_HOST = "your-tunnel-host.trycloudflare.com"
# CHROMA_HTTP_PORT = "443"
# CHROMA_HTTP_SSL  = "true"
# CHROMA_HTTP_TOKEN = "선택-인증토큰"
