# 비공개 설정 (API 키 등)
.env
.env.*
!.env.example
.streamlit/secrets.toml

# KEITI 원본 데이터(저작권=한국환경산업기술원) — 재인덱싱용 로컬 전용, 커밋 금지
# 런타임은 커밋된 storage/ 산출물만 사용한다.
data/

# 파이썬
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# 가상환경 / 도구 캐시
.venv/
venv/
.ruff_cache/
.mypy_cache/
.pytest_cache/
.cache/
.python-version

# 에디터 / 도구 로컬 설정
.claude/
.idea/
.vscode/

# 인덱스 산출물 — 로컬 전용(재생성 가능)은 제외
# 로컬 Chroma DB (대용량)
storage/chroma/
# 로그
storage/*.log
# 구 bge 산출물(미사용)
storage/bm25.pkl
storage/reports.npz
# 임시 산출물
storage/embed_input.jsonl
storage/embeddings_bge.npz
# 검증/테스트 부산물
storage/*.err
storage/*.png
# 커밋 대상(배포 memory 백엔드용):
#   storage/chunks.jsonl, storage/reports_openai.npz, storage/bm25_openai.pkl

# 프론트엔드(React/Vite)
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.tsbuildinfo
**/*.tsbuildinfo
# tsc -b 가 vite.config.ts 를 컴파일해 남기는 산출물(소스는 .ts 만 커밋)
frontend/vite.config.js
frontend/vite.config.d.ts

# OS
.DS_Store
Thumbs.db
.gstack/
