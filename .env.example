# ── 환경설정 템플릿 (이 파일은 커밋해도 됨) ──
# 실제 사용 시: 이 파일을 복사해 .env 로 만들고 값을 채우세요.  cp .env.example .env
OPENAI_API_KEY=sk-여기에-본인-키-입력
OPENAI_MODEL=gpt-5.4-nano
OPENAI_EMBED_MODEL=text-embedding-3-large
OPENAI_EMBED_DIM=0
# 리랭킹 (off | openai)
RERANK_BACKEND=openai
# 벡터 저장소 (chroma=로컬개발 | memory=배포 | remote=원격Chroma)
VECTOR_BACKEND=chroma
# (선택) OpenAI 공식 외 호환 엔드포인트 쓸 때만
OPENAI_BASE_URL=
